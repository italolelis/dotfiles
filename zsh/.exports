# Environment variable exports
# NOTE: All PATH modifications live in .path — do NOT add PATH exports here.

# Locale
export LANG='en_US.UTF-8'
export LC_ALL='en_US.UTF-8'

# Default applications
export EDITOR="cursor"
export VISUAL="cursor"
export PAGER="less"

# Starship prompt config location (wires starship/.starship.toml Stow package)
export STARSHIP_CONFIG="$HOME/.starship.toml"

# Node.js and npm
export NODE_ENV=development
export npm_config_prefix="$HOME/.npm-global"

# Docker optimizations for macOS
export DOCKER_BUILDKIT=1
export COMPOSE_DOCKER_CLI_BUILD=1

# Homebrew privacy
export HOMEBREW_NO_ANALYTICS=1
export HOMEBREW_NO_INSECURE_REDIRECT=1

# Google Cloud SDK auth plugin
export USE_GKE_GCLOUD_AUTH_PLUGIN=True

# macOS fork safety (TODO: verify if still needed on current macOS)
export OBJC_DISABLE_INITIALIZE_FORK_SAFETY=YES
